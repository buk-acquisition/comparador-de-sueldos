    <!-- LÓGICA DEL COMPARADOR (Vanilla JS) -->
    <script>
        // Formateador de moneda CLP
        const formatCLP = (num) => {
            return '$' + Math.round(num).toLocaleString('es-CL');
        };

        // LÓGICA DEL MODAL DE CAPTACIÓN (LEADS)
        function abrirModalLead() {
            // Validar que se haya ingresado un sueldo antes de pedir los datos
            const sueldoInput = parseFloat(document.getElementById('sueldo').value) || 0;
            if (sueldoInput <= 0) {
                alert("Por favor, ingresa un sueldo mensual válido para poder compararlo.");
                document.getElementById('sueldo').focus();
                return;
            }
            
            const modal = document.getElementById('lead-modal');
            const content = document.getElementById('lead-modal-content');
            
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            
            // Timeout para permitir la transición fluida
            setTimeout(() => {
                modal.classList.remove('opacity-0');
                content.classList.remove('scale-95');
            }, 10);
        }

        function cerrarModalLead() {
            const modal = document.getElementById('lead-modal');
            const content = document.getElementById('lead-modal-content');
            
            modal.classList.add('opacity-0');
            content.classList.add('scale-95');
            
            setTimeout(() => {
                modal.classList.remove('flex');
                modal.classList.add('hidden');
            }, 300);
        }

        function procesarLead(event) {
            event.preventDefault(); // Evita recargar la página al enviar el formulario
            cerrarModalLead();
            
            // Muestra los resultados una vez enviado el formulario
            setTimeout(() => {
                compararSueldo();
            }, 300);
        }

        // BASE DE DATOS SIMULADA (Basada en la Encuesta Buk 2025 del documento)
        const marketData = {
            "gerente_finanzas": {
                pequena: { p25: 3400000, p50: 4304000, p75: 5200000 },
                mediana: { p25: 3497000, p50: 5414000, p75: 7146000 },
                gran:    { p25: 4500000, p50: 6160000, p75: 8062000 },
                industrias: {
                    energia: 8933000, inmobiliarias: 7443000, transporte: 6863000, manufactura: 6500000, finanzas: 8000000, general: 5414000
                },
                topIndustrias: [
                    { name: "Energía", val: 8933000 },
                    { name: "Inmobiliarias", val: 7443000 },
                    { name: "Transporte y logística", val: 6863000 }
                ]
            },
            "jefe_contabilidad": {
                pequena: { p25: 2800000, p50: 3439000, p75: 4100000 },
                mediana: { p25: 2600000, p50: 3206000, p75: 3800000 },
                gran:    { p25: 2700000, p50: 3237000, p75: 4100000 },
                industrias: {
                    energia: 3310000, manufactura: 3566000, finanzas: 3215000, inmobiliarias: 3100000, transporte: 3000000, general: 3206000
                },
                topIndustrias: [
                    { name: "Manufactura", val: 3566000 },
                    { name: "Energía", val: 3310000 },
                    { name: "Finanzas y seguros", val: 3215000 }
                ]
            },
            "analista_financiero": {
                pequena: { p25: 1600000, p50: 2128000, p75: 2668000 },
                mediana: { p25: 1508000, p50: 1931000, p75: 2300000 },
                gran:    { p25: 1550000, p50: 1996000, p75: 2400000 },
                industrias: {
                    finanzas: 2213000, energia: 2100000, manufactura: 2000000, inmobiliarias: 1900000, transporte: 1850000, general: 1931000
                },
                topIndustrias: [
                    { name: "Finanzas y seguros", val: 2213000 },
                    { name: "Energía", val: 2100000 },
                    { name: "Manufactura", val: 2000000 }
                ]
            },
            "jefe_tesoreria": {
                pequena: { p25: 1800000, p50: 2248000, p75: 3015000 },
                mediana: { p25: 1700000, p50: 2293000, p75: 2800000 },
                gran:    { p25: 1646000, p50: 2144000, p75: 2600000 },
                industrias: {
                    finanzas: 2500000, energia: 2400000, manufactura: 2300000, inmobiliarias: 2200000, transporte: 2100000, general: 2293000
                },
                topIndustrias: [
                    { name: "Finanzas y seguros", val: 2500000 },
                    { name: "Energía", val: 2400000 },
                    { name: "Manufactura", val: 2300000 }
                ]
            }
        };

        // Función Principal de Comparación
        function compararSueldo() {
            // 1. Obtener valores
            const cargo = document.getElementById('cargo').value;
            const tamano = document.querySelector('input[name="tamano"]:checked').value;
            const industriaKey = document.getElementById('industria').value;
            const sueldoInput = parseFloat(document.getElementById('sueldo').value) || 0;

            if (sueldoInput <= 0) return alert("Por favor ingresa un sueldo válido.");

            // 2. Extraer datos del mercado
            const data = marketData[cargo];
            const sizeData = data[tamano];
            const indMedian = data.industrias[industriaKey] || sizeData.p50;

            // 3. Evaluar Posición
            let status = "";
            let dotColor = "";
            let textColor = "";
            let percentageText = "";
            let positionPercent = 50; // Para el gráfico (0 a 100)

            // Lógica de cálculo visual (aproximación lineal entre percentiles)
            if (sueldoInput < sizeData.p25) {
                status = "Bajo el mercado";
                dotColor = "bg-red-500";
                textColor = "text-red-600";
                percentageText = "Tu sueldo está por debajo del p25 del mercado para este cargo y tipo de empresa.";
                // Rango visual 0% - 25%
                const ratio = Math.max(0, sueldoInput / sizeData.p25);
                positionPercent = ratio * 25;

            } else if (sueldoInput > sizeData.p75) {
                status = "Sobre el mercado";
                dotColor = "bg-buk-blue";
                textColor = "text-buk-blue";
                percentageText = "Tu sueldo está por sobre el 75% de los profesionales de tu cargo en este tipo de empresa.";
                // Rango visual 75% - 100% (tope max en 95% para no salirse de la caja)
                const extra = sueldoInput - sizeData.p75;
                const range = sizeData.p75 * 0.5; // Estimamos un 50% extra como tope
                const ratio = Math.min(1, extra / range);
                positionPercent = 75 + (ratio * 20);

            } else {
                status = "En rango de mercado";
                dotColor = "bg-buk-yellow";
                textColor = "text-yellow-600";
                percentageText = "Tu sueldo está dentro de la banda salarial competitiva del mercado (entre p25 y p75).";
                // Rango visual 25% - 75%
                const range = sizeData.p75 - sizeData.p25;
                const progress = sueldoInput - sizeData.p25;
                const ratio = progress / range;
                positionPercent = 25 + (ratio * 50);
            }

            // Asegurar que el marker visual quede en un rango seguro (5% a 95%)
            positionPercent = Math.max(5, Math.min(95, positionPercent));

            // Diferencias monetarias
            const diffSize = sueldoInput - sizeData.p50;
            const diffSizeStr = diffSize >= 0 ? `+${formatCLP(diffSize)}` : `${formatCLP(diffSize)}`;
            const diffInd = sueldoInput - indMedian;
            const diffIndStr = diffInd >= 0 ? `+${formatCLP(diffInd)}` : `${formatCLP(diffInd)}`;

            // 4. Actualizar DOM
            const tamanoLabels = { pequena: "pequeña", mediana: "mediana", gran: "gran" };
            document.getElementById('res-title').innerText = `Tu posición en ${tamanoLabels[tamano]} empresa`;
            
            // Status Pill
            document.getElementById('status-text').innerText = status;
            document.getElementById('status-text').className = `font-bold text-sm ${textColor}`;
            document.getElementById('status-pill').className = `inline-flex items-center gap-2 border-2 rounded-full px-6 py-2 ${textColor.replace('text-', 'border-')}`;
            document.getElementById('status-dot').className = `w-3 h-3 rounded-full ${dotColor}`;

            // Labels del gráfico
            document.getElementById('lbl-p25').innerText = formatCLP(sizeData.p25);
            document.getElementById('lbl-p50').innerText = formatCLP(sizeData.p50);
            document.getElementById('lbl-p75').innerText = formatCLP(sizeData.p75);

            // Mover el Marker
            document.getElementById('user-marker').style.left = `${positionPercent}%`;

            // Textos de conclusión
            document.getElementById('res-conclusion').innerText = percentageText;
            document.getElementById('res-diff').innerText = `${diffSizeStr} respecto a la mediana (p50)`;
            document.getElementById('res-diff').className = `font-bold text-sm ${diffSize >= 0 ? 'text-buk-blue' : 'text-red-500'}`;

            // Tarjeta Industria
            document.getElementById('ind-mediana').innerText = formatCLP(indMedian);
            document.getElementById('ind-diff').innerText = `${diffIndStr} respecto a la mediana de tu sector`;
            
            // Renderizar Top Industrias
            const ul = document.getElementById('ind-top-list');
            ul.innerHTML = '';
            data.topIndustrias.forEach((ind, i) => {
                const li = document.createElement('li');
                li.className = `flex justify-between ${i < 2 ? 'border-b border-buk-line pb-2' : ''}`;
                li.innerHTML = `<span>${ind.name}</span><span>${formatCLP(ind.val)}</span>`;
                ul.appendChild(li);
            });

            // 5. Mostrar y Scroll
            const box = document.getElementById('resultado-box');
            box.classList.remove('hidden');
            box.classList.add('flex');
            
            setTimeout(() => {
                box.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 100);
        }

        // Acordeón FAQ Simple
        const faqs = [
            { q: "¿Cuál es el sueldo de un Gerente de Finanzas en Chile?", a: "El sueldo mediano varía según el tamaño de la organización: en pequeñas empresas la mediana es de $4.304.000, en medianas es de $5.414.000 y en grandes corporaciones llega a $6.160.000 brutos mensuales. Los salarios más competitivos (p75) pueden superar los 8 millones." },
            { q: "¿Cuánto gana un Jefe de Contabilidad o Analista Financiero?", a: "El sueldo mediano de un Jefe de Contabilidad ronda los $3.206.000 en empresas medianas. Por su parte, un Analista Financiero percibe una mediana de $1.931.000 en el mismo segmento, siendo el sector de Finanzas y Seguros el que mejor paga para ambos roles." },
            { q: "¿Qué factores influyen en las bandas salariales de finanzas?", a: "Principalmente el tamaño de la empresa (facturación y dotación) y la industria. Mientras los cargos gerenciales muestran grandes diferencias de sueldo según el tamaño de la empresa, los perfiles analíticos y contables tienden a mantener escalas salariales más similares sin importar el tamaño." },
            { q: "¿Qué significa estar 'bajo el mercado' o 'sobre el mercado' salarial?", a: "Estar 'bajo el mercado' significa percibir un sueldo inferior al percentil 25 (p25) de tu cargo e industria. Estar 'sobre el mercado' es ganar por encima del percentil 75 (p75). La zona competitiva o 'en rango' se encuentra entre el p25 y el p75." },
            { q: "¿De dónde provienen los datos de este comparador de sueldos?", a: "La información salarial proviene de la Encuesta de Remuneraciones Buk 2025, un estudio que consolida, anonimiza y analiza los datos reales de nómina de miles de empresas que operan con nuestra plataforma en Chile." }
        ];

        const faqContainer = document.getElementById('faq-container');
        faqs.forEach((faq, index) => {
            const div = document.createElement('div');
            div.className = "bg-white border border-buk-line rounded-xl overflow-hidden shadow-sm";
            div.innerHTML = `
                <button class="w-full flex justify-between items-center p-5 text-left font-bold text-buk-darkBlue hover:bg-buk-bg transition-colors" onclick="toggleFaq(${index})">
                    <span>${faq.q}</span>
                    <span id="icon-${index}" class="text-buk-blue text-2xl font-black leading-none">+</span>
                </button>
                <div id="answer-${index}" class="hidden px-5 pb-5 text-buk-darkBlue/80 leading-relaxed border-t border-buk-line/50 pt-4">
                    ${faq.a}
                </div>
            `;
            faqContainer.appendChild(div);
        });

        function toggleFaq(index) {
            const answer = document.getElementById(`answer-${index}`);
            const icon = document.getElementById(`icon-${index}`);
            if (answer.classList.contains('hidden')) {
                answer.classList.remove('hidden');
                icon.innerText = '−';
            } else {
                answer.classList.add('hidden');
                icon.innerText = '+';
            }
        }
    </script>
